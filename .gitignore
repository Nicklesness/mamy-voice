# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# generated audio files
public/audio/*.mp3
!public/audio/winnie-the-pooh-demo.mp3
public/audio/*.wav
public/audio/*.webm
data/audio/
data/books/

# image generation scripts (contain API keys)
generate_images.py

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma
generate_landing_images.py
generate_book_covers.py
